{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard",
  "version": "0.1.0",
  "identifier": "com.jasonhong.clipboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clipboard",
        "width": 360,
        "height": 480,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "resizable": false,
        "fullscreen": false
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "/?window=settings",
        "width": 420,
        "height": 550,
        "decorations": false,
        "transparent": false,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}